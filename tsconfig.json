{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "resolveJsonModule": true,

    "strict": true,
    "isolatedModules": true,
    "noEmit": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "types": [
      "@cloudflare/workers-types"
    ]
  }
}