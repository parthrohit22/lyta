{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lyta",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-10",

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Conversation"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["SessionIndex"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["AuthDirectory", "Workspace"]
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "CONVERSATION",
        "class_name": "Conversation"
      },
      {
        "name": "SESSION_INDEX",
        "class_name": "SessionIndex"
      },
      {
        "name": "AUTH_DIRECTORY",
        "class_name": "AuthDirectory"
      },
      {
        "name": "WORKSPACE",
        "class_name": "Workspace"
      }
    ]
  },

  "ai": {
    "binding": "AI",
    "remote": true
  },

  "assets": {
    "directory": "./pages"
  },

  "compatibility_flags": ["nodejs_compat"]
}
